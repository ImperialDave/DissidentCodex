<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.codex.app">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- For image picking on modern Android -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:name=".CodexApplication"
        android:allowBackup="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.Codex"
        android:supportsRtl="true">

        <!-- Auth entry point -->
        <activity
            android:name=".auth.AuthActivity"
            android:exported="true"
            android:theme="@style/Theme.Codex">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main app (internal only; launched explicitly from AuthActivity) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Codex" />

        <!-- Post detail -->
        <activity
            android:name=".ui.PostDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <!-- Mod / Admin tools (only reachable from UI when privileged) -->
        <activity
            android:name=".ui.ModToolsActivity"
            android:exported="false"
            android:theme="@style/Theme.Codex" />

        <!-- Founder-only tools (ericdanielevans@gmail.com exclusive full control menu) -->
        <activity
            android:name=".ui.FounderToolsActivity"
            android:exported="false"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.ChatRoomActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.NewMessageActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.SearchHubActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.BrowseTopicsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.ModerationManageActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.LeaderboardActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.UserProfileActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.FriendsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.ChessLobbyActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:theme="@style/Theme.Codex" />

        <activity
            android:name=".ui.ChessGameActivity"
            android:exported="false"
            android:parentActivityName=".ui.ChessLobbyActivity"
            android:theme="@style/Theme.Codex" />

    </application>

</manifest>