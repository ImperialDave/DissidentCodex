<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/codexBackground">

    <!-- Top bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_close"
        app:title="Discussion" />

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/typingPreview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Author header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/detailAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/default_avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/detailAuthor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/detailRoleBadge"
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/detailTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/detailHideBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/hide_from_feed"
                    android:textColor="?attr/codexAccent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Delete on detail for privileged -->
                <ImageView
                    android:id="@+id/detailDeleteBtn"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_delete"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/detailHiddenBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/surface_variant"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="@string/hidden_from_feed_badge"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <com.google.android.material.chip.Chip
                android:id="@+id/detailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/detailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/on_surface"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/detailImage"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="14dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <!-- Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/detailLikeIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_like" />

                <TextView
                    android:id="@+id/detailLikeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/on_surface_variant" />

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_comment" />

                <TextView
                    android:id="@+id/detailCommentCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/on_surface_variant" />

                <!-- Share feature -->
                <ImageView
                    android:id="@+id/shareButton"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_send"
                    android:contentDescription="Share post" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/surface_variant" />

            <!-- Comments header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/comments"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/commentsRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/noCommentsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/no_comments"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/typingPreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        android:ellipsize="end"
        android:maxLines="3"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textColor="?attr/codexOnSurface"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/replyBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/replyBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/commentMediaPreviewRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/replyHintText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?attr/codexAccent"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/cancelReplyBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/cancel_reply"
            android:padding="4dp"
            android:src="@drawable/ic_close" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/commentMediaPreviewRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/commentBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/commentMediaPreview"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/add_gif"
            android:textColor="?attr/codexOnSurfaceVariant"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/removeCommentMediaBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/remove_media"
            android:padding="4dp"
            android:src="@drawable/ic_close" />
    </LinearLayout>

    <!-- Comment input bar -->
    <LinearLayout
        android:id="@+id/commentBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/attachCommentMediaBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/attach_media"
            android:padding="4dp"
            android:src="@drawable/ic_image" />

        <ImageView
            android:id="@+id/attachCommentVideoBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/attach_comment_video"
            android:padding="4dp"
            android:src="@drawable/ic_chat" />

        <EditText
            android:id="@+id/commentInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/comment_input_bg"
            android:hint="@string/add_comment"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:minHeight="48dp"
            android:padding="10dp"
            android:scrollHorizontally="false"
            android:textColor="?attr/codexOnSurface"
            android:textColorHint="?attr/codexOnSurfaceVariant"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/sendCommentBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:padding="6dp"
            android:src="@drawable/ic_send" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>