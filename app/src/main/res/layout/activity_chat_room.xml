<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/codexBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_close"
        app:title="@string/live_chat" />

    <TextView
        android:id="@+id/lockedBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexAccentLight"
        android:drawableStart="@drawable/ic_lock"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="@string/topic_locked_banner"
        android:textColor="?attr/codexAccent"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/typingPreview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lockedBanner" />

    <TextView
        android:id="@+id/emptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/message_hint"
        android:textColor="?attr/codexOnSurfaceVariant"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/typingPreview"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lockedBanner" />

    <TextView
        android:id="@+id/typingPreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        android:ellipsize="end"
        android:maxLines="3"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:textColor="?attr/codexOnSurface"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/mediaPreviewRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/mediaPreviewRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/messageBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/mediaPreview"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/mediaPreviewLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/add_gif"
            android:textColor="?attr/codexOnSurfaceVariant"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/removeMediaBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="@string/remove_media"
            android:padding="4dp"
            android:src="@drawable/ic_close" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/messageBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/attachMediaBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/attach_media"
            android:padding="6dp"
            android:src="@drawable/ic_image"
            app:tint="?attr/codexAccent" />

        <ImageView
            android:id="@+id/attachVideoBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/attach_video"
            android:padding="6dp"
            android:src="@drawable/ic_comment"
            app:tint="?attr/codexAccent" />

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/comment_input_bg"
            android:hint="@string/message_hint"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="4"
            android:minHeight="48dp"
            android:padding="10dp"
            android:scrollHorizontally="false"
            android:textColor="?attr/codexOnSurface"
            android:textColorHint="?attr/codexOnSurfaceVariant"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/sendBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:contentDescription="@string/message_sent"
            android:minHeight="48dp"
            android:padding="6dp"
            android:src="@drawable/ic_send"
            app:tint="?attr/codexAccent" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>