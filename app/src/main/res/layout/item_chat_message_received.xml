<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/msgAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/default_avatar" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="48dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/msgAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/codexOnSurface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/msgRoleBadge"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_chat_bubble_received"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/msgMedia"
                android:layout_width="220dp"
                android:layout_height="160dp"
                android:layout_marginBottom="4dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <androidx.media3.ui.PlayerView
                android:id="@+id/msgVideo"
                android:layout_width="220dp"
                android:layout_height="160dp"
                android:layout_marginBottom="4dp"
                android:visibility="gone"
                app:show_buffering="when_playing"
                app:use_controller="true" />

            <TextView
                android:id="@+id/msgBubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/codexOnSurface"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/msgTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="?attr/codexOnSurfaceVariant"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>