<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/codexBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/create_post"
            android:textColor="@color/on_surface"
            android:textSize="26sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/post_title"
            app:boxBackgroundColor="@color/surface"
            app:boxStrokeColor="@color/accent"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/titleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/post_body"
            app:boxBackgroundColor="@color/surface"
            app:boxStrokeColor="@color/accent"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/bodyInput"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textColor="@color/on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- User-created category -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/category_hint"
            app:boxBackgroundColor="?attr/codexSurface"
            app:boxStrokeColor="?attr/codexAccent"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/categoryInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLength="40"
                android:textColor="?attr/codexOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/existing_categories"
            android:textColor="?attr/codexOnSurfaceVariant"
            android:textSize="12sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categorySuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- Image section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addImageButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_image"
                android:textAllCaps="false"
                app:icon="@drawable/ic_image"
                app:iconTint="@color/accent"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <TextView
                android:id="@+id/imageNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/removeImageButton"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_close"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Preview image -->
        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="10dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:background="@color/surface_variant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/publishButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="@string/publish"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="14dp" />

        <!-- Draft controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveDraftButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/save_draft"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearDraftButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_draft"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/accent_light"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- UI Improvement 4: Simple live post preview -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Live Preview (how it will appear in feed)"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/postPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@color/surface"
            android:padding="8dp"
            android:textColor="@color/on_surface"
            android:textSize="13sp"
            android:text="Your post preview will appear here as you type..." />

    </LinearLayout>
</ScrollView>