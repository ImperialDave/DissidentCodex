<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/modToolsRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mod_tools_title"
            android:textColor="@color/on_surface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Search active users, manage roles, and moderate content."
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manageTopicsBtn"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="52dp"
            android:text="@string/manage_topics_categories"
            android:textAllCaps="false"
            app:icon="@drawable/ic_shield_mod"
            app:iconGravity="textStart" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/manage_topics_short_hint"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/statTotalText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@color/surface"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="@color/on_surface"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/statActiveText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@color/surface"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="@color/success"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/statSuspendedText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@color/surface"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="@color/warning"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/statBannedText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@color/surface"
                android:gravity="center"
                android:padding="10dp"
                android:textColor="@color/error"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- User Management -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/user_management"
            android:textColor="@color/warning"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="@color/surface"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/userSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_users_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:textColor="@color/on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/userFilterChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAllUsers"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/all_users" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipActiveOnly"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/active_users_only" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/userListStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/usersRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/usersEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/no_users_match"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshUsersBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/refresh"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TextButton" />

        <!-- Post Moderation -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/post_moderation"
            android:textColor="@color/warning"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="@color/surface"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/postSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_posts_hint"
                android:inputType="text"
                android:textColor="@color/on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshPostsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/refresh"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TextButton" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/modPostsRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/modEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/no_posts"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Comment Moderation -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/comment_moderation"
            android:textColor="@color/warning"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshCommentsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/refresh"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TextButton" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/commentsRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/commentsEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/no_comments_mod"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Chat Moderation -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/chat_moderation"
            android:textColor="@color/warning"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshChatBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/refresh"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TextButton" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatMessagesRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/chatEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/no_chat_messages_mod"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Topic Rooms -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/topic_rooms_mod"
            android:textColor="@color/warning"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshTopicsBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/refresh"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TextButton" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/topicRoomsRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/topicsEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/no_topic_rooms"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@color/surface_variant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/mod_tip"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>