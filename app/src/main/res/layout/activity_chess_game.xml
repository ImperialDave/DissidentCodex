<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/codexBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/codexSurface"
        app:navigationIcon="@drawable/ic_close"
        app:title="@string/chess_game" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="12dp"
        android:textColor="?attr/codexOnSurface"
        android:textSize="15sp" />

    <com.codex.app.chess.ChessBoardView
        android:id="@+id/chessBoard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="8dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/challengeActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/acceptBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/chess_accept_play"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/declineBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/decline"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/activeActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/resignBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chess_resign"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>
</LinearLayout>